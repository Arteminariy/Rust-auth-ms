# --- Server ---
BIND_ADDR=0.0.0.0:8000
RUST_LOG=info,auth_ms_api=debug,tower_http=info

# --- Database ---
DATABASE_URL=postgres://auth_ms:auth_ms@localhost:5432/auth_ms

# --- JWT (Phase 0: HS256; Phase 3: switch to RS256) ---
JWT_SECRET=change-me-in-prod-please-use-32+chars
JWT_ACCESS_TTL=900          # 15 minutes
JWT_REFRESH_TTL=2592000     # 30 days

# --- Bootstrap admin (created on first start if absent) ---
INITIAL_ADMIN_PASSWORD=admin123

# --- Migrations ---
# Set to "false" in K8s/init-container/sidecar-Job patterns so the API
# container doesn't race with the migration job.
RUN_MIGRATIONS=true

# --- Email (Phase 2 schema; Phase 0a: pluggable trait only) ---
# EMAIL__BACKEND=smtp        # smtp | file
# EMAIL__SMTP__HOST=smtp.example.com
# EMAIL__SMTP__PORT=587
# EMAIL__SMTP__USER=apikey
# EMAIL__SMTP__PASS=secret
# EMAIL__SMTP__FROM=no-reply@example.com
